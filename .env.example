# VocabMaster 环境变量模板
# 使用：cp .env.example .env 然后按实际环境修改

# ========== 通用 ==========
VM_ENV=dev                        # dev | staging | prod

# ========== 数据库 ==========
VM_DB_HOST=localhost
VM_DB_PORT=3306
VM_DB_NAME=vocabmaster
VM_DB_USER=vocab
VM_DB_PASSWORD=vocab123

# Python 版需要 DSN 风格
VM_DB_DSN=mysql+aiomysql://vocab:vocab123@localhost:3306/vocabmaster

# ========== Redis ==========
VM_REDIS_HOST=localhost
VM_REDIS_PORT=6379
VM_REDIS_PASSWORD=redis123
VM_REDIS_DB=0
VM_REDIS_URL=redis://:redis123@localhost:6379/0

# ========== 加密密钥（生产必须改！）==========
# JWT 签名密钥（HS256），至少 32 字符
# 生成命令：openssl rand -hex 32
VM_JWT_SECRET=dev-secret-change-in-production-must-be-32chars-plus

# 手机号 AES-256-GCM 加密密钥（base64 编码的 32 字节）
# 生成命令：openssl rand -base64 32
VM_PHONE_AES_KEY=dev-aes-key-must-be-32bytes-base64=

# ========== JWT 配置 ==========
VM_JWT_ACCESS_EXPIRES=7200        # 2 小时（秒）
VM_JWT_REFRESH_EXPIRES=604800     # 7 天（秒）
VM_JWT_ISSUER=vocabmaster

# ========== 微信小程序（需要自行申请）==========
VM_WX_APPID=wx_your_appid_here
VM_WX_SECRET=wx_your_secret_here

# ========== Apple 登录（iOS App 上架需要）==========
VM_APPLE_CLIENT_ID=com.vocabmaster.app
VM_APPLE_TEAM_ID=your_team_id
VM_APPLE_KEY_ID=your_key_id
VM_APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# ========== 短信服务（可选，用于手机验证码）==========
# 阿里云
VM_SMS_PROVIDER=aliyun            # aliyun | tencent | mock
VM_SMS_ACCESS_KEY_ID=
VM_SMS_ACCESS_KEY_SECRET=
VM_SMS_SIGN_NAME=VocabMaster
VM_SMS_TEMPLATE_CODE=SMS_123456789

# ========== 邮件服务 ==========
VM_MAIL_HOST=smtp.example.com
VM_MAIL_PORT=465
VM_MAIL_USER=noreply@vocabmaster.com
VM_MAIL_PASSWORD=
VM_MAIL_FROM=VocabMaster <noreply@vocabmaster.com>

# ========== 对象存储（用户头像、词库音频/图片）==========
VM_OSS_PROVIDER=minio             # minio | aliyun | aws_s3
VM_OSS_ENDPOINT=http://localhost:9000
VM_OSS_ACCESS_KEY=minioadmin
VM_OSS_SECRET_KEY=minioadmin
VM_OSS_BUCKET=vocabmaster
VM_OSS_PUBLIC_URL=http://localhost:9000/vocabmaster

# ========== 日志 ==========
VM_LOG_LEVEL=INFO                 # DEBUG | INFO | WARN | ERROR
VM_LOG_DIR=./logs

# ========== 监控（可选）==========
VM_PROMETHEUS_ENABLED=true
VM_SENTRY_DSN=

# ========== 业务参数 ==========
VM_DAILY_NEW_DEFAULT=20           # 默认每日新词数
VM_DAILY_REVIEW_MAX=200           # 单日最大复习量（防止积压过多）
VM_SYNC_BATCH_SIZE=100            # 同步接口单次最大条数
VM_WORD_IMPORT_BATCH=500          # 词库导入批大小

# ========== 开发环境专用 ==========
VM_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
VM_SWAGGER_ENABLED=true           # 生产环境记得设 false
